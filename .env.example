NODE_ENV=development
# Use 4000 when Admin Panel (Next) runs on 3000
PORT=4000

# Neon PostgreSQL (SSL required)
DB_HOST=your-project-pooler.region.aws.neon.tech
DB_PORT=5432
DB_NAME=neondb
DB_USER=neondb_owner
DB_PASSWORD=your_neon_password
DB_SSL=true
DB_POOL_MAX=10

DB_TABLE_MATE_NAME=neondb

LOG_LEVEL=info

JWT_SECRET=your_long_random_jwt_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=compney-api
JWT_AUDIENCE=compney-client
JWT_COOKIE_NAME=access_token
JWT_COOKIE_MAX_AGE_MS=604800000

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/

CORS_ORIGIN=http://localhost:3000
