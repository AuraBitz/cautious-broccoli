NODE_ENV=development
PORT=3000

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=compney
DB_USER=compney
DB_PASSWORD=your_password
DB_SSL=false
DB_POOL_MAX=10

DB_TABLE_MATE_NAME=table_mate

LOG_LEVEL=info

JWT_SECRET=your_long_random_jwt_secret
JWT_EXPIRES_IN=7d
JWT_ISSUER=compney-api
JWT_AUDIENCE=compney-client
JWT_COOKIE_NAME=access_token
JWT_COOKIE_MAX_AGE_MS=604800000

COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/

CORS_ORIGIN=http://localhost:5173
